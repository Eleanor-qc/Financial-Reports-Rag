   "source": [
    "import pdfplumber\n",
    "\n",
    "texts = []\n",
    "with pdfplumber.open(\"amazon_2023.pdf\") as pdf:\n",
    "    for i, page in enumerate(pdf.pages):\n",
    "        text = page.extract_text()\n",
    "        if text:\n",
    "            texts.append({\n",
    "                \"page\": i + 1,\n",
    "                \"text\": text\n",
    "            })"
   ]
  }
 ],
